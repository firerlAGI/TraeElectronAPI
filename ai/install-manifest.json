{
  "schemaVersion": 1,
  "language": "zh-CN",
  "product": "TraeAPI OpenClaw Integration",
  "repo": "https://github.com/firerlAGI/TraeElectronAPI",
  "preferredPlatform": "windows",
  "pluginId": "trae-ide",
  "tools": ["trae_status", "trae_delegate"],
  "source": {
    "repoZipUrl": "https://github.com/firerlAGI/TraeElectronAPI/archive/refs/heads/main.zip",
    "bootstrapScriptUrl": "https://raw.githubusercontent.com/firerlAGI/TraeElectronAPI/main/scripts/bootstrap-openclaw-integration.ps1"
  },
  "install": {
    "preferredScript": "scripts/bootstrap-openclaw-integration.ps1",
    "localScript": "scripts/install-openclaw-integration.ps1",
    "quickstartCommand": "start-traeapi.cmd"
  },
  "verify": [
    "openclaw plugins info trae-ide",
    "openclaw config validate"
  ],
  "notes": [
    "Do not try to install the plugin from a GitHub URL directly.",
    "Download the repo or bootstrap script first, then install locally.",
    "After install, restart OpenClaw Gateway before calling trae_status."
  ]
}
